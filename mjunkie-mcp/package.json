{
  "name": "mjunkie-mcp",
  "version": "1.0.0",
  "description": "Multimedia Junkie MCP Server – Sovereign Engine API bridge for autonomous content generation and spatial dashboard rendering.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts",
    "db": "json-server --watch db.json --port 3000",
    "test": "bun run build && node --test tests/",
    "lint": "tsc --noEmit"
  },
  "keywords": ["mcp", "multimedia", "sovereign-engine", "space-agent"],
  "author": "Multimedia Junkie",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "json-server": "^1.0.0-beta.3",
    "typescript": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
